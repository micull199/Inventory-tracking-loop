# Copy this file to `.env` and fill in real values.
# Never commit `.env`. Only `.env.example` is in version control.

# ---- core ----------------------------------------------------------------

# SQLAlchemy database URL.
# Dev (default): SQLite file in the project root.
# Prod: postgresql+psycopg://USER:PASSWORD@HOST:PORT/DBNAME
DATABASE_URL=sqlite:///./dev.db

# Secret used to sign session cookies. Generate with:
#   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=change-me

# Absolute base URL of the running app. Used for OAuth redirect URIs and email links.
APP_BASE_URL=http://localhost:8000

# `dev` enables auto-reload, verbose errors. `prod` is strict.
APP_ENV=dev

# ---- Google SSO ----------------------------------------------------------

# Created in Google Cloud Console → APIs & Services → Credentials → OAuth 2.0 Client ID
# Authorised redirect URI must match: ${APP_BASE_URL}/auth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. If set, only Google accounts in this Workspace domain can sign in.
# Leave blank for no domain restriction.
GOOGLE_HOSTED_DOMAIN=

# ---- email ---------------------------------------------------------------

# `console` prints emails to stdout (dev). `smtp` sends them for real.
EMAIL_BACKEND=console

# Required when EMAIL_BACKEND=smtp.
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=inventory@example.com
SMTP_USE_TLS=true

# ---- misc ---------------------------------------------------------------

# Used to seed the very first Admin user. The first Google sign-in matching this
# email is auto-promoted to Admin instead of landing in pending state.
# Leave blank in prod after the first run.
BOOTSTRAP_ADMIN_EMAIL=
